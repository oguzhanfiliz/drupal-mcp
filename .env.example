# MCP Server Authentication Token
MCP_TOKEN=change-me-to-a-secure-token

# Default Drupal root (optional, can also be configured in config.yaml)
DRUPAL_ROOT=/path/to/drupal/project

# Config sync directory relative to DRUPAL_ROOT (default: config/sync)
CONFIG_SYNC_DIR=config/sync

# Drush path (default: uses ddev drush)
DRUSH_PATH=ddev drush

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Audit log file path
AUDIT_LOG_PATH=./logs/audit.log

# Rate limit (requests per minute per tool)
RATE_LIMIT_RPM=60

# Max response size in characters
MAX_RESPONSE_SIZE=50000

# Environment label
ENVIRONMENT=development
